{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": false,
    "outDir": ".vercel/output",
    "noEmit": false,
    "allowJs": true,
    "types": ["node", "@vercel/node"]
  },
  "include": ["api/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
