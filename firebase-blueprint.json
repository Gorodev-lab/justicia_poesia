{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Firebase Auth UID"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "displayName": {
          "type": "string",
          "description": "User's display name"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Account creation timestamp"
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "User role for RBAC"
        }
      },
      "required": ["uid", "email", "createdAt", "role"]
    },
    "Phrase": {
      "title": "Phrase",
      "description": "A generated Huchití phrase",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the phrase"
        },
        "authorUid": {
          "type": "string",
          "description": "UID of the user who generated the phrase"
        },
        "originalText": {
          "type": "string",
          "description": "The original Spanish text"
        },
        "generatedPhrase": {
          "type": "string",
          "description": "The generated Huchití phrase"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the phrase was generated"
        }
      },
      "required": ["id", "authorUid", "originalText", "generatedPhrase", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles"
    },
    "phrases/{phraseId}": {
      "schema": {
        "$ref": "#/entities/Phrase"
      },
      "description": "Stores generated phrases"
    }
  }
}
